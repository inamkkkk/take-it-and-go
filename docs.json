{
  "docs": [
    {
      "file": "package.json",
      "summary": "Configuration file for the takeitgo-lite-backend Node.js project. Defines project metadata, scripts for development and production, and lists project dependencies."
    },
    {
      "file": ".env.example",
      "type": "config",
      "summary": "Environment variables for application configuration.",
      "config_variables": [
        {
          "name": "PORT",
          "description": "The port number the application will listen on. Defaults to 3000.",
          "example": "3000"
        },
        {
          "name": "MONGO_URI",
          "description": "The connection URI for the MongoDB database.",
          "example": "mongodb://localhost:27017/takeitgo-lite-db"
        },
        {
          "name": "JWT_SECRET",
          "description": "The secret key used for signing JSON Web Tokens (JWTs).",
          "example": "supersecretjwtkey"
        },
        {
          "name": "JWT_EXPIRES_IN",
          "description": "The expiration time for JWTs. This is a time duration string (e.g., '1h', '7d').",
          "example": "1h"
        },
        {
          "name": "GOOGLE_MAPS_API_KEY",
          "description": "Optional: API key for Google Maps integration. Uncomment and provide your key if needed.",
          "example": "YOUR_GOOGLE_MAPS_API_KEY",
          "optional": true
        }
      ]
    },
    {
      "file": "server.js",
      "summary": "Main server file for the Take iT & Go Lite API. Sets up Express, Socket.IO, connects to MongoDB, and defines middleware and routes. Includes error handling and graceful shutdown.",
      "config": [
        {
          "description": "Loads environment variables from a .env file.",
          "module": "dotenv",
          "function": "config()"
        },
        {
          "description": "Initializes Express application.",
          "module": "express"
        },
        {
          "description": "Creates an HTTP server using the Express app.",
          "module": "http",
          "function": "createServer(app)"
        },
        {
          "description": "Initializes Socket.IO server with CORS configuration.",
          "module": "socket.io",
          "function": "Server(server, { cors: { origin: process.env.CLIENT_URL || \"*\", methods: [\"GET\", \"POST\"] } })"
        },
        {
          "description": "Connects to the MongoDB database.",
          "module": "./src/config/db",
          "function": "connectDB()"
        }
      ],
      "middleware": [
        {
          "description": "Enables Cross-Origin Resource Sharing.",
          "module": "cors",
          "function": "app.use(cors())"
        },
        {
          "description": "Parses incoming JSON requests.",
          "module": "express",
          "function": "app.use(express.json())"
        },
        {
          "description": "Parses incoming URL-encoded requests.",
          "module": "express",
          "function": "app.use(express.urlencoded({ extended: true }))"
        },
        {
          "description": "Logs incoming requests.",
          "module": "./src/middlewares/loggerMiddleware",
          "function": "app.use(loggerMiddleware)"
        },
        {
          "description": "Handles all unhandled errors centrally.",
          "module": "./src/middlewares/errorHandler",
          "function": "app.use(errorHandler)"
        }
      ],
      "routes": [
        {
          "method": "GET",
          "path": "/",
          "summary": "Health check endpoint for the API.",
          "response": {
            "200": {
              "message": "Take iT & Go Lite API is running!"
            }
          }
        },
        {
          "method": "USE",
          "path": "/api",
          "summary": "Mounts all API routes defined in ./src/routes.",
          "description": "All subsequent API requests will be routed through this path."
        }
      ],
      "sockets": [
        {
          "description": "Initializes and registers the chat socket handler.",
          "module": "./src/sockets/chatSocket",
          "function": "chatSocketHandler(io)"
        }
      ],
      "eventHandlers": [
        {
          "event": "unhandledRejection",
          "description": "Logs unhandled promise rejections and gracefully shuts down the server.",
          "handler": "process.on('unhandledRejection', (err, promise) => { ... })"
        },
        {
          "event": "uncaughtException",
          "description": "Logs uncaught exceptions and gracefully shuts down the server.",
          "handler": "process.on('uncaughtException', (err) => { ... })"
        }
      ]
    },
    {
      "file": "src/config/db.js",
      "type": "utility",
      "summary": "Establishes a connection to the MongoDB database using Mongoose."
    },
    {
      "file": "src/utils/logger.js",
      "summary": "Configuration for the application logger using Winston. This utility sets up logging levels, formats, and transports (files and console for development). It ensures errors are logged with stack traces and messages are formatted for readability and JSON compatibility."
    },
    {
      "file": "src/utils/apiError.js",
      "summary": "Custom error class for API-related errors, extending Node.js's built-in Error class. Includes a statusCode property to denote HTTP status codes and an isOperational flag to distinguish from programming errors."
    },
    {
      "file": "src/utils/hash.js",
      "summary": "Utility functions for password hashing and comparison using bcrypt."
    },
    {
      "file": "src/utils/jwt.js",
      "summary": "Utility functions for JWT (JSON Web Token) generation and verification."
    },
    {
      "file": "src/middlewares/loggerMiddleware.js",
      "summary": "A middleware function that logs incoming HTTP requests."
    },
    {
      "file": "src/middlewares/errorHandler.js",
      "summary": "Custom error handling middleware to process and format API errors.",
      "utility": {
        "description": "This middleware intercepts errors thrown within the application, standardizes them into an 'ApiError' format, and sends a consistent JSON response to the client. It specifically handles common errors like Mongoose CastErrors, duplicate keys, validation errors, and Joi validation errors, translating them into user-friendly messages and appropriate HTTP status codes. For unhandled errors, it defaults to a 500 Internal Server Error.",
        "details": [
          "Handles Mongoose 'CastError' (e.g., invalid ObjectId format) with a 404 status.",
          "Handles Mongoose duplicate key errors (code 11000) with a 400 status.",
          "Handles Mongoose 'ValidationError' with a 400 status, aggregating validation messages.",
          "Handles Joi validation errors ('isJoi' property) with a 400 status, aggregating detail messages.",
          "Logs all errors to the configured logger for debugging purposes.",
          "Forwards unhandled errors with a default 500 status code."
        ]
      }
    },
    {
      "file": "src/middlewares/authMiddleware.js",
      "summary": "Provides middleware functions for authentication and authorization.",
      "middleware": [
        {
          "name": "protect",
          "summary": "Protects routes by verifying JWT tokens and attaching user information to the request object.",
          "description": "This middleware checks for a JWT token in the 'Authorization' header (Bearer schema). If a valid token is found, it verifies the token, retrieves the associated user from the database, and attaches the user object (excluding the password) to `req.user`. If the token is missing, invalid, or the user is not found, it returns an appropriate `ApiError`.",
          "requestHeaders": {
            "Authorization": "string (Bearer <token>)"
          },
          "responsePayloads": {
            "401": {
              "error": "string"
            }
          }
        },
        {
          "name": "authorize",
          "summary": "Authorizes routes based on user roles.",
          "description": "This middleware takes a variable number of roles as arguments. It checks if the authenticated user (`req.user`) has one of the specified roles. If not, it returns a `403 Forbidden` error.",
          "parameters": [
            {
              "name": "roles",
              "type": "string[]",
              "description": "An array of allowed user roles."
            }
          ],
          "responsePayloads": {
            "403": {
              "error": "string"
            }
          }
        }
      ]
    },
    {
      "file": "src/middlewares/validationMiddleware.js",
      "summary": "Middleware for validating request bodies against Joi schemas.",
      "utility": {
        "name": "validate",
        "description": "Creates a validation middleware for a given Joi schema. It validates the request body, updates it with the validated and stripped value, and passes it to the next middleware or route handler. If validation fails, it passes the Joi error to the error handler.",
        "parameters": [
          {
            "name": "schema",
            "type": "Joi.Schema",
            "description": "The Joi schema to validate the request body against."
          }
        ],
        "returns": {
          "type": "function",
          "description": "A middleware function with signature (req, res, next)."
        }
      }
    },
    {
      "file": "src/models/User.js",
      "schema": {
        "email": {
          "type": "string",
          "required": true,
          "unique": true,
          "description": "User's email address",
          "validation": {
            "pattern": "/^[\\w-\\.]+@([\\w-]+\\.)+[\\w-]{2,4}$/",
            "message": "Please add a valid email"
          }
        },
        "phone": {
          "type": "string",
          "required": true,
          "unique": true,
          "description": "User's phone number",
          "validation": {
            "pattern": "/^[+]?[(]?[0-9]{3}[)]?[-\\s.]?[0-9]{3}[-\\s.]?[0-9]{4,6}$/",
            "message": "Please add a valid phone number"
          }
        },
        "password": {
          "type": "string",
          "required": true,
          "description": "User's password",
          "validation": {
            "minLength": 6,
            "message": "Password must be at least 6 characters"
          },
          "select": false
        },
        "role": {
          "type": "string",
          "enum": [
            "shipper",
            "traveler"
          ],
          "default": "shipper",
          "description": "User's role within the system"
        },
        "createdAt": {
          "type": "date",
          "default": "Date.now",
          "description": "Timestamp of when the user was created"
        }
      },
      "hooks": [
        {
          "event": "pre('save')",
          "description": "Hashes the password before saving the user document to the database."
        }
      ]
    },
    {
      "file": "src/models/Delivery.js",
      "schema": {
        "shipperId": {
          "type": "ObjectId",
          "ref": "User",
          "required": true
        },
        "travelerId": {
          "type": "ObjectId",
          "ref": "User",
          "default": null
        },
        "pickup": {
          "type": "Object",
          "required": true,
          "properties": {
            "address": {
              "type": "string"
            },
            "lat": {
              "type": "number"
            },
            "lng": {
              "type": "number"
            }
          }
        },
        "drop": {
          "type": "Object",
          "required": true,
          "properties": {
            "address": {
              "type": "string"
            },
            "lat": {
              "type": "number"
            },
            "lng": {
              "type": "number"
            }
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "matched",
            "in-transit",
            "delivered",
            "cancelled"
          ],
          "default": "pending"
        },
        "createdAt": {
          "type": "Date",
          "default": "Date.now"
        },
        "itemDescription": {
          "type": "string",
          "required": false
        },
        "price": {
          "type": "number",
          "required": false
        }
      }
    },
    {
      "file": "src/models/Payment.js",
      "schema": {
        "deliveryId": {
          "type": "ObjectId",
          "ref": "Delivery",
          "required": true,
          "description": "Reference to the associated delivery."
        },
        "amount": {
          "type": "Number",
          "required": true,
          "min": 0,
          "description": "The payment amount."
        },
        "status": {
          "type": "String",
          "enum": [
            "pending",
            "completed",
            "refunded",
            "failed"
          ],
          "default": "pending",
          "description": "The current status of the payment."
        },
        "transactionId": {
          "type": "String",
          "unique": true,
          "sparse": true,
          "description": "Unique identifier for the transaction from the payment service. Allows null values."
        },
        "createdAt": {
          "type": "Date",
          "default": "Date.now",
          "description": "Timestamp when the payment record was created."
        }
      }
    },
    {
      "file": "src/models/Chat.js",
      "schema": {
        "Chat": {
          "deliveryId": {
            "type": "ObjectId",
            "ref": "Delivery",
            "required": true,
            "description": "Reference to the Delivery document this chat belongs to."
          },
          "senderId": {
            "type": "ObjectId",
            "ref": "User",
            "required": true,
            "description": "Reference to the User document of the sender."
          },
          "receiverId": {
            "type": "ObjectId",
            "ref": "User",
            "required": true,
            "description": "Reference to the User document of the receiver."
          },
          "message": {
            "type": "string",
            "required": true,
            "trim": true,
            "description": "The content of the chat message."
          },
          "timestamp": {
            "type": "Date",
            "default": "Date.now",
            "description": "The timestamp when the message was created."
          },
          "read": {
            "type": "boolean",
            "default": false,
            "description": "Indicates whether the message has been read by the receiver."
          }
        }
      }
    },
    {
      "file": "src/models/GpsLog.js",
      "schema": {
        "GpsLog": {
          "deliveryId": {
            "type": "ObjectId",
            "ref": "Delivery",
            "required": true,
            "description": "Reference to the associated Delivery"
          },
          "lat": {
            "type": "Number",
            "required": true,
            "description": "Latitude coordinate"
          },
          "lng": {
            "type": "Number",
            "required": true,
            "description": "Longitude coordinate"
          },
          "timestamp": {
            "type": "Date",
            "default": "Date.now",
            "description": "Timestamp of the GPS log entry"
          }
        }
      }
    },
